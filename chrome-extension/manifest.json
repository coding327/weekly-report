{
  "manifest_version": 3,
  "name": "AI 周报生成器",
  "version": "1.0.0",
  "description": "输入关键词，AI 帮你写周报。摸鱼神器。",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI 周报生成器",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://api.deepseek.com/*"
  ]
}
